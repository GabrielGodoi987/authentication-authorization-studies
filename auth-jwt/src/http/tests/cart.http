@baseUrl = http://localhost:3000/carts
@api-token = Jesus_is_my_savior
@access-token = paste-a-valid-access-token-here
@cartId = paste-a-valid-cart-id-here
@productId = 00000000-0000-0000-0000-000000000000

### Create a new cart
# @name CreateCartAction
POST {{baseUrl}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

### Get cart by user ID
# @name FindAuthenticatedUserCartAction
GET {{baseUrl}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

### Get cart by cart ID
# @name FindCartByIdAction
GET {{baseUrl}}/{{cartId}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

### Add product to cart
# @name AddProductToCartAction
POST {{baseUrl}}/{{cartId}}/products
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

{
  "productId": "{{productId}}",
  "productName": "Product Name",
  "quantity": 2,
  "price": 20
}

### Delete cart by ID
# @name DeleteCartAction
DELETE {{baseUrl}}/{{cartId}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

### Update product quantity in cart
# @name UpdateCartProductQuantityAction
PUT {{baseUrl}}/{{cartId}}/products/{{productId}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

{
  "quantity": 3
}

### Remove product from cart
# @name RemoveProductFromCartAction
DELETE {{baseUrl}}/{{cartId}}/products/{{productId}}
Content-Type: application/json
x-api-token: {{api-token}}
Authorization: Bearer {{access-token}}

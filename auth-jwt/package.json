{
  "name": "auth-jwt",
  "version": "1.0.0",
  "description": "",
  "main": "app.ts",
  "scripts": {
    "test": "jest --selectProjects unit",
    "test:e2e": "jest --selectProjects e2e",
    "test:all": "jest",
    "start:dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/app.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "npx typeorm-ts-node-commonjs migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/database/source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/source.ts",
    "schema:drop": "npm run typeorm -- schema:drop -d src/database/source.ts",
    "seed": "ts-node src/database/seeds/main.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}